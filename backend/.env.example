# Copy this file to backend/.env and fill in real values.

# Server
PORT=5000

# MongoDB (required for auth)
# Local:  mongodb://127.0.0.1:27017/zarr
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/zarr?retryWrites=true&w=majority
MONGO_URI=

# JWT
JWT_SECRET=please-change-me-in-production
JWT_EXPIRES_IN=30d

# Shopify storefront
#
# We use Shopify's public REST catalog endpoints (no auth needed):
#   /products.json, /collections.json, /products/{handle}.json,
#   /collections/{handle}/products.json
# These are exposed by every Shopify storefront and return real product
# and collection data. Just set the public domain of the store.
SHOPIFY_STORE_DOMAIN=zarr.com.pk
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
